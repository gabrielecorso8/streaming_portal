# Virtual environment
venv/

# Local cache and temporary files
__pycache__/
*.pyc
tmp/

# Downloaded media + runtime download state (not shared)
downloads/
server.log
downloads_state.json

# Local binaries (ffmpeg) — too large for the repo
bin/

# NOTE: library.json, settings.json and covers/ are intentionally TRACKED
# so the curated collection (titles, folders, cover images) ships with the repo.

# PyInstaller build output (l'eseguibile si rigenera con "Crea EXE.bat")
build/
dist/
*.exe

# File locali dell'agente (non vanno nel repo)
.claude/

# Backup locali della migrazione link
*.bak_link_migration
